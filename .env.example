# 漏洞哨兵 V11.6 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# JWT 密钥（生产环境必须修改！至少 32 位随机字符串）
JWT_SECRET=your-super-secret-key-here-change-me

# JWT Token 过期时间（秒），默认 24 小时
JWT_EXPIRE_SECONDS=86400

# 数据库目录，生产环境建议 /data（Render 持久化磁盘）
DB_DIR=/data
DB_NAME=scans.db

# 扫描超时时间（秒）
SCAN_TIMEOUT=12

# 深度扫描最大爬取页面数
MAX_CRAWL_PAGES=8

# 限速配置（每分钟请求数）
RATE_LIMIT_GLOBAL_PER_MINUTE=30
RATE_LIMIT_SCAN_PER_MINUTE=10
RATE_LIMIT_FIX_PER_MINUTE=10

# CORS 白名单（生产环境必须显式配置，多个用逗号分隔）
# 兼容 ALLOWED_ORIGINS 和 CORS_ORIGINS 两个变量名
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 是否验证 TLS 证书（V11.6 默认 true；安全产品必须优先保证通信安全）
# 设置为 false 可启用"不安全兼容模式"，结果会标记为"诊断用途"
TLS_VERIFY=true

# ============== V11.6 AI 顾问 LLM 配置（可选） ==============
# 设置 LLM_ENABLED=true 启用真实 LLM；不设置则用本地规则（关键字匹配）
LLM_ENABLED=false
# LLM 提供方：openai / deepseek / qwen / custom
LLM_PROVIDER=openai
# 你的 API Key（务必保密，不要提交到 git）
LLM_API_KEY=
# 自定义 base_url（可选；不同 provider 有默认）
LLM_BASE_URL=https://api.openai.com/v1
# 模型名
LLM_MODEL=gpt-4o-mini
# LLM 超时（秒）
LLM_TIMEOUT=15

# ============== V11.6 自动巡检 ==============
# 巡检间隔（小时），默认 6
PATROL_INTERVAL_HOURS=6
# 评分下滑阈值（超过此值就告警）
PATROL_SCORE_REGRESSION_THRESHOLD=10

# ============== V11.6 公开演示 ==============
# 是否允许未登录用户查看公共演示数据
PUBLIC_DEMO_ENABLED=true

# ============== V11.6 本地演示靶场 ==============
# 是否允许扫描 localhost/127.0.0.1（本地演示用，生产环境建议关闭）
ALLOW_LOCALHOST=true
# 内网白名单（逗号分隔，用于扫描内网靶场）
# ALLOWED_INTERNAL_HOSTS=192.168.1.100,pikachu.local

# ============== V11.6 凭证加密（生产环境必须设置） ==============
# 凭证加密密钥（base64 编码的 32 字节密钥）
# 生成命令：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CREDENTIAL_ENCRYPT_KEY=your-encryption-key-here

# ============== 生产环境标记 ==============
# 设置为 1 启用生产模式（强制 JWT 密钥校验、强制凭证加密密钥等安全检查）
# PRODUCTION=1

